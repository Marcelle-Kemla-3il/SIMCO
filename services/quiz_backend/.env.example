# SIMCO Backend Environment Variables

# Application Settings
APP_NAME=SIMCO - Cognitive Evaluation System
DEBUG=true

# PostgreSQL
# Example: postgresql://postgres:postgres@localhost:5432/simco
DATABASE_URL=

# SQLite fallback (used when DATABASE_URL is empty)
SQLITE_DB_PATH=data/sessions.db

# JSON export (always saved for easy viewing)
JSON_SESSIONS_DIR=data/sessions_json

# Ollama LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# SIMCO Logic neural service
SIMCO_LOGIC_BASE_URL=http://localhost:8010

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session Management
SESSION_TIMEOUT=3600

# Quiz Settings
DEFAULT_QUIZ_LENGTH=10
DEFAULT_TIME_LIMIT=1200

# Behavioral Analysis
WEBCAM_ENABLED=true
BLINK_RATE_THRESHOLD=30.0
HEAD_MOVEMENT_THRESHOLD=5.0
GAZE_STABILITY_THRESHOLD=0.6

# ===========================================
# SIMCO - Configuration Environment File
# ===========================================

# Database Configuration
# =====================
# SQLite (par défaut, simple)
DATABASE_URL=sqlite:///./simco.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/simco_db

# LLM Configuration
# ==================
LLM_PROVIDER=ollama

# Ollama (LLM local recommandé)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini

# OpenAI (alternative)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Mistral (alternative)
MISTRAL_API_KEY=your-mistral-api-key-here

# Computer Vision Configuration
# ============================
# MediaPipe (optionnel, pour analyse faciale avancée)
MEDIAPIPE_ENABLED=false

# OpenFace (optionnel, pour extraction de features avancées)
# OPENFACE_BIN=C:/OpenFace/build/bin/FeatureExtraction.exe
# OPENFACE_BIN=/usr/local/bin/OpenFace

# API Configuration
# ==================
API_V1_STR=/api/v1
PROJECT_NAME=SIMCO
VERSION=1.0.0

# Security
# ========
SECRET_KEY=votre-secret-key-tres-long-et-unique-ici
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Development/Production
# =====================
DEBUG=true
ENVIRONMENT=development

# Logging
# =======
LOG_LEVEL=INFO

# CORS Configuration
# =================
ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000", "http://127.0.0.1:3000", "http://127.0.0.1:8000"]

# File Upload Configuration
# =========================
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=./uploads

# ML Model Configuration
# ======================
MODEL_PATH=./models
DEFAULT_MODEL=random_forest_v1.joblib

# Cache Configuration
# ===================
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600  # 1 hour

# Features Flags
# ==============
ENABLE_FACIAL_ANALYSIS=true
ENABLE_VOICE_ANALYSIS=false
ENABLE_BIOMETRIC_AUTH=false

# Email / SMTP Configuration
# ==========================
# Configure these to enable email sending of PDF results.
# For Gmail (use an App Password, not your main password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_USE_TLS=true
# EMAIL_FROM=your_email@gmail.com


# ===========================================
# Instructions :
# 1. Copiez ce fichier en .env
# 2. Modifiez les valeurs selon votre configuration
# 3. Ne partagez jamais votre fichier .env !
# ===========================================

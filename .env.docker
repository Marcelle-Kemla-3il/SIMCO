########################################
# Frontend
########################################
VITE_API_BASE_URL=http://localhost:8080

########################################
# Backend / CORS
########################################
ALLOWED_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:5173","http://127.0.0.1:5173"]

########################################
# Admin (Basic Auth) - à surcharger en prod
########################################
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

########################################
# LLM (Docker)
########################################
# Choisir un provider:
# - mistral  : via API Mistral (MISTRAL_API_KEY nécessaire)
# - ollama   : via serveur Ollama local (host.docker.internal)
# - local    : uniquement banques locales (aucun appel LLM)
LLM_PROVIDER=mistral

# Mistral API (Option 1)
MISTRAL_API_KEY=
MISTRAL_API_URL=https://api.mistral.ai
MISTRAL_MODEL=mistral-small-latest

# Ollama (Option 2 — si tu veux basculer plus tard)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
